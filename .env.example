# Supabase — projet "Skalesy Marketplace"
# Récupère ces valeurs dans : Dashboard Supabase → Project Settings → API
# La clé "anon/publishable" est PUBLIQUE (embarquée côté navigateur), pas un secret.
NEXT_PUBLIC_SUPABASE_URL=https://ncxkanufcozjbbchrwmy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=remplace-par-ta-cle-anon-publishable

# URL publique de l'app (utilisée pour les liens magiques d'authentification).
# En local : http://localhost:3000 — en prod : l'URL Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clé "service_role" Supabase — SECRET (Dashboard → Project Settings → API).
# Côté SERVEUR uniquement (jamais préfixée NEXT_PUBLIC_). Requise pour l'API admin
# qui envoie les invitations de membres. À définir en local ET dans Vercel.
SUPABASE_SERVICE_ROLE_KEY=remplace-par-ta-cle-service-role

# Clé API Resend — SECRET. Utilisée par Supabase (SMTP custom) pour envoyer les
# emails d'auth ; à saisir côté Supabase, pas ici. Cette variable n'est requise
# QUE si l'app se met à envoyer des emails en direct (notifications). Optionnelle.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
